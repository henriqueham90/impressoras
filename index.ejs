<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Gerenciador de Postagens</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .post-card { background: white; border: 1px solid #dbdbdb; border-radius: 8px; margin-bottom: 20px; padding: 15px; }
        #editor-container { height: 200px; background: white; }
    </style>
</head>
<body class="container py-5">

    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4 text-center">Nova Postagem</h2>
            
            <!-- Formulário com Editor -->
            <form action="/postar" method="POST" id="postForm">
                <div id="editor-container"></div>
                <input type="hidden" name="conteudo" id="conteudo">
                <button type="submit" class="btn btn-primary mt-3 w-100">Publicar Texto</button>
            </form>

            <hr class="my-5">

            <!-- Feed de Visualização/Edição -->
            <h2 class="mb-4">Suas Postagens</h2>
            <div id="feed">
                <% posts.forEach(post => { %>
                    <div class="post-card shadow-sm">
                        <small class="text-muted">Postado em <%= post.data %></small>
                        <div class="mt-2">
                            <%- post.conteudo %> <!-- Renderiza o HTML formatado -->
                        </div>
                        <div class="mt-3 d-flex gap-2">
                            <form action="/deletar/<%= post.id %>" method="POST">
                                <button class="btn btn-sm btn-outline-danger">Excluir</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- Scripts do Quill -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script>
        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: 'Digite e formate seu texto aqui...',
            modules: {
                toolbar: [
                    ['bold', 'italic', 'underline'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link', 'clean']
                ]
            }
        });

        // Antes de enviar o form, coloca o HTML do editor no input hidden
        document.getElementById('postForm').onsubmit = function() {
            var conteudo = document.querySelector('input[name=conteudo]');
            conteudo.value = quill.root.innerHTML;
        };
    </script>
</body>
</html>
